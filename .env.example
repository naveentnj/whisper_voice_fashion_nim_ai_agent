# ─────────────────────────────────────────────────────────────────
# VALENTI AI – Environment Variables Template
# Copy this file to .env and fill in your own keys
# ─────────────────────────────────────────────────────────────────

# HuggingFace API key (for cloud Whisper ASR + model downloads)
# Get yours at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your_key_here

# NVIDIA NIM API key (for LLM tool calling via CrewAI agents)
# Get yours at: https://build.nvidia.com
NVIDIA_NIM_API_KEY=nvapi-your_key_here

# Tavily Search API (optional, for agent web search tool)
TAVILY_API_KEY=tvly-your_key_here

# SERP API (optional, for agent search tool)
SERP_API_KEY=your_serp_key_here

# ─────────────────────────────────────────────────────────────────
# MongoDB Configuration
# ─────────────────────────────────────────────────────────────────

# Atlas (cloud) — recommended. URL-encode special chars in password:
#   , -> %2C    > -> %3E    [ -> %5B    ] -> %5D    @ -> %40
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp

# Local fallback (used if Atlas is unreachable)
MONGODB_URI_LOCAL=mongodb://localhost:27017

# Database name
MONGODB_DB=valenti_ai
